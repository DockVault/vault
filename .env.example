# =============================================================================
# Vault service — .env template
# =============================================================================
# Copy to .env and fill in the secrets. Every key here maps to a field in
# config.py (Settings); case-insensitive. Unknown keys are ignored.
#
# HOW THIS FILE IS USED depending on how you run the vault:
#   * Standalone HTTPS deploy (docker-compose.secure.yml + setup-secure.sh):
#     setup-secure.sh GENERATES your .env. That compose file also sets
#     DATABASE_URL, REDIS_HOST/PORT, API_*, SFTP_HOST/PORT, ENVIRONMENT and
#     SETUP_STATE_FILE in its own `environment:` block, and a compose
#     `environment:` value OVERRIDES anything in .env — so for that deploy the
#     only .env keys that matter are the SECRETS, the ADMIN_* bootstrap, the
#     "standalone deploy" helpers, COMPOSE_PROFILES/SFTP_HOST_PORT, and the
#     "optional tuning" knobs further down. The infra keys below are shown for
#     reference / bare-metal use.
#   * Dev stack (docker-compose.yml via scripts/up.ps1): likewise overrides the
#     infra keys and runs ENVIRONMENT=development.
#   * Bare metal (no compose): every key below is read from this file.
#
# *** Keep .env at mode 600 and BACK IT UP off the host — it holds ENCRYPTION_KEY,
#     the at-rest master key. Lose it and every stored file is unrecoverable. ***

# =============================================================================
# REQUIRED secrets
# =============================================================================
# ENCRYPTION_KEY — Fernet at-rest master key. Generate ONCE for a new install:
#   openssl rand -base64 32 | tr '+/' '-_'
#   (or: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
# ⚠️ NEVER regenerate on a vault that already stores data — it becomes undecryptable.
ENCRYPTION_KEY=your_fernet_key_here

# JWT_SECRET_KEY — signs session/access tokens. Safe to rotate (forces re-login):
#   openssl rand -hex 32   (or: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET_KEY=your_jwt_secret_key_here

# VAULT_DB_PASSWORD — the Postgres password. Both compose files build DATABASE_URL
# from it and set POSTGRES_PASSWORD from it. Generate:  openssl rand -hex 16
# ⚠️ Postgres bakes this in on FIRST init of its data volume; changing it later
#    also requires ALTER USER inside Postgres (or wiping the volume).
VAULT_DB_PASSWORD=your_db_password_here

# =============================================================================
# Admin bootstrap (creates the first admin ONLY if no admin exists yet;
# change the password later in the web UI — editing it here is then a no-op)
# =============================================================================
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD — generate a strong one:  openssl rand -base64 18
# Left as an obvious placeholder ON PURPOSE: the app REFUSES to boot with this exact placeholder in
# ANY environment (and, when ENVIRONMENT=production, also with any other known sample/weak value or
# one shorter than 12 characters), so a verbatim copy of this file can't create an admin with a
# publicly known or trivially weak password.
ADMIN_PASSWORD=REPLACE_ME

# =============================================================================
# Standalone HTTPS deploy helpers (docker-compose.secure.yml)
# =============================================================================
# Remembered by setup-secure.sh so re-runs / --certs-only don't re-prompt.
# The vault app itself ignores these (pydantic extra='ignore').
# SERVER_NAME=vault.example.com
# CERT_MODE=1                       # 1=self-signed  2=Let's Encrypt  3=bring-your-own

# Enable the optional SFTP service (uncomment). Omit to stay HTTPS-443-only.
# COMPOSE_PROFILES=sftp
# Host-side SFTP port for docker-compose.secure.yml (default 2322; the
# container-internal port stays 2222). Set to avoid a clash / match your NSG.
# SFTP_HOST_PORT=2322

# =============================================================================
# Database (overridden by both compose files)
# =============================================================================
DATABASE_URL=postgresql://sftp_user:your_db_password_here@localhost:5432/sftp_db

# =============================================================================
# Redis (host/port overridden by both compose files)
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
# Keep Redis failures fast so the fail-closed login-throttle DB fallback kicks in.
REDIS_CONNECT_TIMEOUT=1.0
REDIS_SOCKET_TIMEOUT=2.0

# =============================================================================
# SFTP server (container-internal; host mapping is set in the compose file)
# =============================================================================
SFTP_HOST=0.0.0.0
SFTP_PORT=2222
SFTP_HOST_KEY_PATH=./keys/ssh_host_rsa_key

# =============================================================================
# API / web server (overridden by the compose files)
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8000
# API_USE_HTTPS=true terminates TLS in-process (uvicorn). docker-compose.secure.yml
# FORCES this true and publishes host 443 -> container 8000. Dev stack runs false.
API_USE_HTTPS=false
API_SSL_CERTFILE=./certs/cert.pem
API_SSL_KEYFILE=./certs/key.pem

# =============================================================================
# Environment  (development | production)
# =============================================================================
# 'development' (vs the default 'production') exposes /docs, /redoc, /openapi.json, relaxes CORS to a
# credentialed localhost origin, skips the stricter admin-password checks applied outside development
# (the sample/weak blocklist + the 12-char minimum), and suppresses the plaintext-HTTP startup
# warning. The shipped ADMIN_PASSWORD placeholder is refused in EVERY environment. Any non-development
# value (production, staging, ...) is treated as reachable; docker-compose.secure.yml forces production.
ENVIRONMENT=production

# =============================================================================
# JWT / sessions
# =============================================================================
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# =============================================================================
# Temporary credentials (least-privilege, time-boxed)
# =============================================================================
TEMP_CRED_VALIDITY_MINUTES=65
TEMP_CRED_SESSION_GRACE_MINUTES=65
TEMP_CRED_TOTAL_LIFETIME_MINUTES=65

# =============================================================================
# File storage
# =============================================================================
FILE_STORAGE_PATH=./storage
MAX_FILE_SIZE_MB=1024
TRANSFER_SPEED_LIMIT_KB=0
# Hours a resumable chunked-upload session lives before its buffered chunks are
# eligible for cleanup (floored at 1h in code).
CHUNK_SESSION_TTL_HOURS=24

# =============================================================================
# Plan-imposed feature ceilings (HARD caps; the control plane injects these at
# provision time). Defaults are PERMISSIVE — leave unset for an un-gated
# standalone vault. -1 = unlimited, 0 = none/blocked, N = capped.
# =============================================================================
# PLAN_ZERO_KNOWLEDGE=true          # may zero-knowledge vaults be created at all
# PLAN_FORCE_ZERO_KNOWLEDGE=false   # plan mandates ZK org-wide (Enterprise)
# PLAN_MAX_ZK_VAULTS=-1             # cap on ZK vaults
# PLAN_MAX_STORAGE_GB=-1            # aggregate storage cap, GB
# PLAN_MAX_USERS=-1                 # cap on user accounts

# =============================================================================
# Rate limiting — login, vault unlock, SFTP key auth, account lockout
# =============================================================================
RATE_LIMIT_LOGIN_ATTEMPTS=5
RATE_LIMIT_LOGIN_WINDOW_SECONDS=300
RATE_LIMIT_VAULT_ATTEMPTS=5
RATE_LIMIT_VAULT_ATTEMPTS_ADMIN=20
RATE_LIMIT_VAULT_WINDOW_SECONDS=300
# Per-IP bound on FAILED SFTP public-key offers (DoS/enumeration bound; fails open).
RATE_LIMIT_SFTP_KEY_ATTEMPTS=30
# Auto-unlock TTL (minutes) for an account locked by failed logins; 0 = permanent.
# (An admin-set lock always stays permanent.)
ACCOUNT_LOCKOUT_MINUTES=15
# Trust X-Forwarded-For only from these peers (CIDR/IP, comma-separated). Empty (the
# default) => trust NO proxy: XFF is ignored and the immediate peer is used. The shipped
# compose maps the port directly (no fronting proxy), so a direct client must not be able
# to forge its IP via XFF. ONLY set this behind a genuine reverse proxy — to that proxy's
# network (e.g. 172.16.0.0/12) — to record real client IPs. TRUST_ALL_PROXIES=true honours
# XFF from any peer (only behind a proxy that strips client-supplied XFF).
TRUSTED_PROXIES=
TRUST_ALL_PROXIES=false
# Optional Host-header allowlist (comma-separated; supports a leading '*.' wildcard). Empty (the
# default) = no Host validation, since a self-hosted vault's served name is deployment-specific.
# Set it to your served hostname(s) to reject a forged/unexpected Host / X-Forwarded-Host
# (link-/cache-poisoning primitive); 'localhost' + '127.0.0.1' stay allowed for the health probe.
# ALLOWED_HOSTS=vault.example.com

# =============================================================================
# Rate limiting — general API endpoints
# =============================================================================
RATE_LIMIT_API_ENABLED=true
RATE_LIMIT_API_DEFAULT=100
RATE_LIMIT_API_DEFAULT_WINDOW=60
RATE_LIMIT_API_AUTH=10
RATE_LIMIT_API_AUTH_WINDOW=60
RATE_LIMIT_API_UPLOAD=20
RATE_LIMIT_API_UPLOAD_WINDOW=60
RATE_LIMIT_API_DOWNLOAD=50
RATE_LIMIT_API_DOWNLOAD_WINDOW=60

# =============================================================================
# Security monitoring thresholds (alerts)
# =============================================================================
SECURITY_FAILED_LOGIN_WARNING=5
SECURITY_FAILED_LOGIN_CRITICAL=10
SECURITY_FAILED_LOGIN_WINDOW=10
SECURITY_RATE_LIMIT_WARNING=5
SECURITY_RATE_LIMIT_CRITICAL=10
SECURITY_BULK_DELETION_THRESHOLD=10
SECURITY_BULK_DELETION_WINDOW=60
SECURITY_RAPID_VAULT_THRESHOLD=5
SECURITY_RAPID_VAULT_WINDOW=30
SECURITY_ALERT_RETENTION_DAYS=90

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=INFO
LOG_FILE_PATH=./logs/sftp_server.log

# =============================================================================
# Branding. Optional — the built-in defaults are the DockVault brand (name, logo,
# favicon, colours), so a fresh/self-hosted instance shows DockVault out of the box.
# Override any BRAND_* to put YOUR brand on the instance (these are env-level defaults;
# the admin Settings editor / DB override wins over them at runtime, and a logo/favicon
# can also be uploaded from the admin UI). See app/config/branding.py for the full list.
# =============================================================================
# BRAND_APP_NAME=My Vault
# BRAND_APP_FULL_NAME=Secure File Transfer Platform
# BRAND_APP_TAGLINE=Encrypted file exchange for your team
# BRAND_COMPANY_NAME=My Company Inc.
# BRAND_COMPANY_URL=https://example.com
# BRAND_SUPPORT_EMAIL=support@example.com
# BRAND_WEBSITE_URL=https://example.com
# BRAND_DOCS_URL=https://example.com/docs
# BRAND_PRIMARY_COLOR=#2563eb
# BRAND_SECONDARY_COLOR=#7c3aed
# BRAND_ACCENT_COLOR=#10b981
# BRAND_ENABLE_SIGNUP=true
# BRAND_ENABLE_2FA=true
# BRAND_GITHUB_URL=https://github.com/example/my-vault
#
# Persistent "powered by DockVault" attribution shown on the login page. A customizing
# tenant CANNOT remove it from the admin editor; only this deploy-level flag hides it
# (e.g. an enterprise tier). Defaults keep the attribution on every instance.
# BRAND_SHOW_POWERED_BY=false
# BRAND_POWERED_BY_NAME=DockVault
# BRAND_POWERED_BY_URL=https://dockvault.io
